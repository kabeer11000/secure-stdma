prefix=/usr/local
libdir=/usr/local/lib
includedir=/usr/local/include/ns3.18

Name: libns3-test
Description: ns-3 module ns3-test
Version: 3.18
Libs: -L${libdir} -Wl,-Bdynamic -lns3.18-test-optimized
Cflags: -I${includedir}
Requires: libns3.18-internet-optimized libns3.18-mobility-optimized libns3.18-applications-optimized libns3.18-csma-optimized libns3.18-bridge-optimized libns3.18-config-store-optimized libns3.18-point-to-point-optimized libns3.18-csma-layout-optimized libns3.18-flow-monitor-optimized libns3.18-wifi-optimized
